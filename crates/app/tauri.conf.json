{
  "$schema": "https://raw.githubusercontent.com/nicehash/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "Prompter",
  "identifier": "com.rxvip.prompter",
  "version": "0.1.0",
  "build": {
    "frontendDist": "./ui"
  },
  "bundle": {
    "icon": [
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Prompter",
        "width": 800,
        "height": 900,
        "minWidth": 600,
        "minHeight": 500,
        "center": true,
        "resizable": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "contentProtected": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [],
      "desktop": {
        "schemes": ["prompter"]
      }
    }
  }

}
